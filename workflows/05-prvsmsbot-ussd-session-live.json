        }
      },
      "id": "w5-live-reply-call",
      "name": "Live Reply -> USSD Send",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1410, 420]
    },
    {
      "parameters": {
        "jsCode": "const data = $getWorkflowStaticData('global');\nif (!data.ussdSessions) data.ussdSessions = {};\nconst input = $input.first().json || {};\nconst root = $('Validate + Route Mode').first().json || {};\nconst chatId = String(root.chat_id || '');\nconst state = data.ussdSessions[chatId] || { active: false, history: [] };\nif (!state.active) {\n  return [{ json: { status: 'idle', chat_id: chatId, error: 'no active live session; use start first' } }];\n}\nconst menu = String(input.response || input.error || '');\nconst nextStep = (state.history?.length || 0) + 1;\nstate.history = state.history || [];\nstate.history.push({ step: nextStep, input: String(root.value || ''), response: menu });\ndata.ussdSessions[chatId] = state;\nreturn [{ json: { status: 'active', chat_id: chatId, menu, history: state.history } }];"
      },
      "id": "w5-live-reply-store",
      "name": "Store Live Reply State",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1650, 420]
    },
    {
      "parameters": {
        "jsCode": "const data = $getWorkflowStaticData('global');\nif (!data.ussdSessions) data.ussdSessions = {};\nconst root = $('Validate + Route Mode').first().json || {};\nconst chatId = String(root.chat_id || '');\nconst state = data.ussdSessions[chatId] || { active: false, history: [] };\nstate.active = false;\ndata.ussdSessions[chatId] = state;\nreturn [{ json: { status: 'cancelled', chat_id: chatId, history: state.history || [] } }];"
      },
