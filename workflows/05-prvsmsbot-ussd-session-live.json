{
  "name": "PRVSMSBOT - USSD Session + Live",
  "nodes": [
    {
      "parameters": {
        "path": "prvsmsbot/ussd/session",
        "httpMethod": "POST",
        "responseMode": "responseNode"
      },
      "id": "w5-webhook",
      "name": "USSD Session Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [160, 360],
      "webhookId": "prvsmsbot-ussd-session"
    },
    {
      "parameters": {
        "jsCode": "const data = $getWorkflowStaticData('global');\nconst headers = $json.headers || {};\nconst body = $json.body || $json;\nconst provided = String(headers['x-prv-bot-token'] || headers['X-Prv-Bot-Token'] || '').trim();\nconst expected = String($env.PRV_BOT_TOKEN || '').trim();\nif (!expected) {\n  return [{ json: { ok: false, status_code: 500, error: 'missing PRV_BOT_TOKEN in n8n env', mode: 'error' } }];\n}\nif (provided !== expected) {\n  return [{ json: { ok: false, status_code: 401, error: 'unauthorized', mode: 'error' } }];\n}\n\nconst hasSteps = Array.isArray(body.steps);\nconst hasAction = typeof body.action === 'string' && body.action.trim().length > 0;\n\nif (hasSteps) {\n  const steps = body.steps.map(s => String(s).trim()).filter(Boolean);\n  if (!steps.length) {\n    return [{ json: { ok: false, status_code: 400, error: 'requires non-empty steps list', mode: 'error' } }];\n  }\n  return [{ json: { ok: true, mode: 'batch', steps } }];\n}\n\nif (hasAction) {\n  const action = String(body.action || '').trim().toLowerCase();\n  const chatId = String(body.chat_id || '').trim();\n  const value = String(body.value || '').trim();\n  if (!chatId) {\n    return [{ json: { ok: false, status_code: 400, error: 'chat_id required for live actions', mode: 'error' } }];\n  }\n  if (!['start','reply','cancel'].includes(action)) {\n    return [{ json: { ok: false, status_code: 400, error: 'action must be start|reply|cancel', mode: 'error' } }];\n  }\n  if ((action === 'start' || action === 'reply') && !value) {\n    return [{ json: { ok: false, status_code: 400, error: 'value required for start/reply', mode: 'error' } }];\n  }\n  if (!data.ussdSessions) data.ussdSessions = {};\n  const state = data.ussdSessions[chatId] || { active: false, history: [] };\n  return [{ json: { ok: true, mode: 'live', action, chat_id: chatId, value, state } }];\n}\n\nreturn [{ json: { ok: false, status_code: 400, error: 'requires either steps[] or action', mode: 'error' } }];"
      },
      "id": "w5-validate",
      "name": "Validate + Route Mode",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [400, 360]
    },
