      "id": "w5-live-start-call",
      "name": "Live Start -> USSD Send",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1410, 280]
    },
    {
      "parameters": {
        "jsCode": "const data = $getWorkflowStaticData('global');\nif (!data.ussdSessions) data.ussdSessions = {};\nconst input = $input.first().json || {};\nconst root = $('Validate + Route Mode').first().json || {};\nconst chatId = String(root.chat_id || '');\nconst state = { active: true, history: [] };\nconst menu = String(input.response || input.error || '');\nstate.history.push({ step: 1, input: String(root.value || ''), response: menu });\ndata.ussdSessions[chatId] = state;\nreturn [{ json: { status: 'active', chat_id: chatId, menu, history: state.history } }];"
      },
      "id": "w5-live-start-store",
      "name": "Store Live Start State",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1650, 280]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{($env.SMSGATE_BASE_URL || 'http://smsgate:5000') + '/ussd/send'}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Admin-Key",
              "value": "={{$env.SMSGATE_ADMIN_KEY}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"code\": $json.value}",
        "options": {
