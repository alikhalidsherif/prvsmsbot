# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=CHANGE_ME_TELEGRAM_BOT_TOKEN

# Comma-separated Telegram user IDs that are allowed to use this bot
ALLOWED_TELEGRAM_USER_IDS=8338441637,943629543

# ── SMSGate gateway ───────────────────────────────────────────────────────────
# Docker-internal URL when running on the same Docker network as smsgate
SMSGATE_BASE_URL=http://smsgate:5000

# Matches ADMIN_KEY in SMSGate's .env file
SMSGATE_ADMIN_KEY=CHANGE_ME_ADMIN_KEY

# HTTP / WebSocket request timeout in seconds (increase for slow modems)
GATEWAY_TIMEOUT_SECONDS=30

# ── Inbound webhook listener ──────────────────────────────────────────────────
# prvsmsbot listens on this address/port for SMSGate push events.
# Set SMSGate's WEBHOOK_URL=http://prvsmsbot:8090/webhook
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8090

# Set to false to suppress delivery-report Telegram notifications
NOTIFY_DELIVERY_REPORTS=true

# ── Message categorisation ────────────────────────────────────────────────────
# Comma-separated substrings that identify service senders (banks, telecom, OTPs)
SERVICE_SENDER_PATTERNS=127,251,Ethio,telebirr,CBE,Awash,Dashen,BOA,bank,otp,code

# Minimum digit count in a phone number to be treated as a personal sender
PERSONAL_SENDER_MIN_DIGITS=10

# Default number of messages returned per /inbox and /outbox page
DEFAULT_PAGE_LIMIT=20
